# ==============================================================================
# Mifrufely Web — Example Environment
# Copia este archivo como `.env` y reemplaza los valores con tus credenciales.
# NUNCA subas tu archivo `.env` real a git (ya está en .gitignore).
# ==============================================================================

# --- APPLICATION ---
APP_NAME="Mifrufely Web"
APP_ENV=development
DEBUG=true
APP_VERSION=1.0.0
API_V1_PREFIX=/api/v1
ADMIN_EMAIL_DOMAIN=mitrufely.com
FRONTEND_URL=http://localhost:5173

# --- SERVER ---
HOST=0.0.0.0
PORT=8000
WORKERS=1

# --- DATABASE (NeonDB PostgreSQL) ---
# Cadena async. Reemplaza con tu conexión real de NeonDB.
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=1800

# --- SECURITY / JWT ---
# Genera una clave de al menos 32 caracteres (ej: openssl rand -hex 32)
SECRET_KEY=replace-me-with-a-long-random-secret-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- CORS ---
# Lista JSON. NUNCA uses ["*"] con allow_credentials=True.
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]
ALLOWED_METHODS=["GET","POST","PUT","PATCH","DELETE","OPTIONS"]
ALLOWED_HEADERS=["Authorization","Content-Type","X-Request-ID","Idempotency-Key"]

# --- REDIS ---
REDIS_URL=redis://redis:6399/0
REDIS_CACHE_TTL=300

# --- CELERY ---
CELERY_BROKER_URL=redis://redis:6399/1
CELERY_RESULT_BACKEND=redis://redis:6399/2

# --- LOGGING ---
LOG_LEVEL=DEBUG
LOG_FORMAT=console

# --- PDF / REPORTES ---
PDF_TEMP_DIR=/tmp/mitrufely/pdf
REPORTS_TEMP_DIR=/tmp/mitrufely/reports

# --- SWEETCOINS ---
SWEETCOINS_CONVERSION_RATE=10
SWEETCOINS_EXPIRY_DAYS=365

# --- RENDER DEPLOYMENT ---
RENDER_EXTERNAL_URL=

# --- GMAIL SMTP ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# --- GOOGLE OAUTH ---
# https://console.cloud.google.com/ -> APIs & Services -> Credentials
GOOGLE_CLIENT_ID=

# --- CLOUDINARY ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- JSON.PE (Consulta DNI / RUC) ---
# Obtén tu token en: https://json.pe/  ->  Inicia sesión -> Dashboard
# Documentación: https://docs.json.pe/api-consulta/endpoint/dni
# Deja vacío para operar en "modo degradado" mientras obtienes tu token.
JSONPE_API_TOKEN=
JSONPE_BASE_URL=https://api.json.pe
# TTL del cache Redis para consultas DNI/RUC (segundos). Default: 24h.
JSONPE_CACHE_TTL_SECONDS=86400
# Timeout HTTP hacia json.pe (segundos).
JSONPE_TIMEOUT_SECONDS=10
